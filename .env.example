# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Vite (browser package — public, safe to expose)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# OAuth Providers (local dev — set in supabase/config.toml env() references)
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=
SUPABASE_AUTH_EXTERNAL_GITHUB_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GITHUB_SECRET=

# OpenAI
OPENAI_API_KEY=

# Brevo (email delivery)
BREVO_API_KEY=

# Encryption master key (AES-256-GCM, base64-encoded 32 bytes)
ENCRYPTION_MASTER_KEY=

# NOTE: Production must disable email/password auth in the Supabase dashboard.
# config.toml enables it for local development convenience only.
