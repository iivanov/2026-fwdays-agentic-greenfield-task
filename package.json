{
  "name": "ai-news-aggregator-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "AI-Powered Personalized News Aggregator Monorepo",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "module",
  "scripts": {
    "typecheck": "tsc --build --noEmit",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "test": "vitest run",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:reset": "supabase db reset",
    "supabase:lint": "supabase db lint --local"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@supabase/server": "^1.3.0",
    "@types/node": "^26.1.0",
    "eslint": "^10.6.0",
    "prettier": "^3.9.4",
    "supabase": "^2.109.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  }
}
